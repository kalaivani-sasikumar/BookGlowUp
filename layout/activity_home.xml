<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
android:layout_height="match_parent"
android:background="#FAF7FF"
    android:id="@+id/main">

<androidx.constraintlayout.widget.ConstraintLayout
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:padding="16dp">


    <!-- Welcome Text -->
    <TextView
        android:id="@+id/welcomeText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Welcome!"
        android:fontFamily="@font/montserratbold"
        android:textSize="22sp"
        android:textStyle="bold"
        android:textColor="#312a44"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"/>


    <!-- Discount Card -->
    <androidx.cardview.widget.CardView
        android:id="@+id/discountCard"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        app:cardCornerRadius="16dp"
        app:cardElevation="8dp"
        app:layout_constraintTop_toBottomOf="@id/welcomeText"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg1"
            android:padding="24dp">

            <TextView
                android:id="@+id/discountTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Special discount"
                android:fontFamily="@font/montserratbold"
                android:textColor="#312a44"
                android:textSize="18sp"
                android:textStyle="bold"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent"/>

            <TextView
                android:id="@+id/discountOffer"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="30% Off Coming Soon"
                android:textColor="#312a44"
                android:textSize="23sp"
                android:textStyle="bold"
                android:fontFamily="@font/montserratbold"
                app:layout_constraintTop_toBottomOf="@id/discountTitle"
                app:layout_constraintStart_toStartOf="parent"
                android:layout_marginTop="8dp"/>

            <TextView
                android:id="@+id/discountDesc"
                android:layout_width="304dp"
                android:layout_height="19dp"
                android:layout_marginTop="4dp"
                android:fontFamily="@font/montserratlight"
                android:text="on All Spa Services Between 9-11 AM"
                android:textColor="#312a44"
                android:textSize="14sp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/discountOffer" />

            <Button
                android:id="@+id/bookNowBtn"
                android:layout_width="wrap_content"
                android:layout_height="48dp"
                android:text="Offer's Starting Next Month"
                android:textColor="@android:color/white"
                android:textStyle="bold"
                android:backgroundTint="#312a44"
                android:fontFamily="@font/montserratbold"
                android:layout_marginTop="12dp"
                app:layout_constraintTop_toBottomOf="@id/discountDesc"
                app:layout_constraintStart_toStartOf="parent"/>

        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.cardview.widget.CardView>

    <!-- Departments Title -->
    <TextView
        android:id="@+id/deptTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Main Departments"
        android:textSize="20sp"
        android:textStyle="bold"
        android:fontFamily="@font/montserratbold"
        android:textColor="#312a44"
        android:layout_marginTop="24dp"
        app:layout_constraintTop_toBottomOf="@id/discountCard"
        app:layout_constraintStart_toStartOf="parent"/>

    <!-- SERVICES ROW 1 -->
    <LinearLayout
        android:id="@+id/row1"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toBottomOf="@id/deptTitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Facial -->

        <!-- Nails -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="69dp"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">

            <ImageView
                android:layout_width="56dp"
                android:layout_height="50dp"
                android:id="@+id/facialIcon"
                android:scaleType="centerInside"
                android:src="@drawable/facial"
                app:tint="#9C27B0" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Facial"
                android:fontFamily="@font/montserratlight"
                android:textColor="#312a44"
                android:textSize="14sp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">

            <ImageView
                android:layout_width="56dp"
                android:layout_height="50dp"
                android:id="@+id/nailIcon"
                android:scaleType="centerInside"
                android:src="@drawable/nail"
                app:tint="#9C27B0" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Nails"
                android:textColor="#312a44"
                android:fontFamily="@font/montserratlight"
                android:textSize="14sp"/>
        </LinearLayout>

        <!-- Makeup -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">

            <ImageView
                android:layout_width="56dp"
                android:layout_height="50dp"
                android:id="@+id/makeupIcon"
                android:scaleType="centerInside"
                android:src="@drawable/makeup"
                app:tint="#9C27B0" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/montserratlight"
                android:textColor="#312a44"
                android:text="Makeup"
                android:textSize="14sp"/>
        </LinearLayout>

        <!-- Hair -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">

            <ImageView
                android:layout_width="56dp"
                android:layout_height="50dp"
                android:scaleType="centerInside"
                android:id="@+id/hairIcon"
                android:src="@drawable/hair"
                app:tint="#9C27B0" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Hair"
                android:textColor="#312a44"
                android:fontFamily="@font/montserratlight"
                android:textSize="14sp"/>
        </LinearLayout>

    </LinearLayout>

    <!-- SERVICES ROW 2 -->
    <LinearLayout
        android:id="@+id/row2"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginTop="20dp"
        android:layout_marginBottom="24dp"
        app:layout_constraintTop_toBottomOf="@id/row1"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Waxing -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">

            <ImageView
                android:layout_width="56dp"
                android:layout_height="50dp"
                android:scaleType="centerInside"
                android:id="@+id/waxingIcon"
                android:src="@drawable/waxing"
                app:tint="#9C27B0" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Waxing"
                android:fontFamily="@font/montserratlight"
                android:textColor="#312a44"
                android:textSize="14sp"/>
        </LinearLayout>

        <!-- Spa -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">

            <ImageView
                android:layout_width="56dp"
                android:layout_height="50dp"
                android:scaleType="centerInside"
                android:src="@drawable/spa"
                android:id="@+id/spaIcon"
                app:tint="#9C27B0" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Spa"
                android:textColor="#312a44"
                android:fontFamily="@font/montserratlight"
                android:textSize="14sp"/>
        </LinearLayout>

        <!-- Massage -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">

            <ImageView
                android:layout_width="56dp"
                android:layout_height="50dp"
                android:scaleType="centerInside"
                android:src="@drawable/thread"
                android:id="@+id/massageIcon"
                app:tint="#9C27B0" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Threading"
                android:fontFamily="@font/montserratlight"
                android:textColor="#312a44"
                android:textSize="14sp"/>
        </LinearLayout>

        <!-- Add-ons -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">

            <ImageView
                android:layout_width="56dp"
                android:layout_height="50dp"
                android:scaleType="centerInside"
                android:src="@drawable/add_on"
                android:id="@+id/addonIcon"
                app:tint="#9C27B0" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Add-Ons"
                android:textColor="#312a44"
                android:fontFamily="@font/montserratlight"
                android:textSize="14sp"/>
        </LinearLayout>

    </LinearLayout>

    <!-- Search Icon -->

    <!-- Cart Icon -->



    <ImageView
        android:id="@+id/imageView3"
        android:layout_width="45dp"
        android:layout_height="45dp"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="10dp"
        app:srcCompat="@drawable/cart2"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/bestTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Popular Services"
        android:textSize="20sp"
        android:textStyle="bold"
        android:textColor="#312a44"
        android:fontFamily="@font/montserratbold"
        android:layout_marginTop="10dp"
        app:layout_constraintTop_toBottomOf="@id/row2"
        app:layout_constraintStart_toStartOf="parent"/>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/bestSellerRecycler"
        android:layout_width="0dp"
        android:layout_height="170dp"
        android:layout_marginTop="10dp"
        android:overScrollMode="never"
        android:clipToPadding="false"
        android:paddingStart="5dp"
        app:layout_constraintTop_toBottomOf="@id/bestTitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>




</androidx.constraintlayout.widget.ConstraintLayout>

</ScrollView>