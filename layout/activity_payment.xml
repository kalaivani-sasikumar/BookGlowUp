<?xml version="1.0" encoding="utf-8"?>

<RelativeLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#312a44"
    android:padding="16dp">


    <TextView
        android:id="@+id/priceTitle"
        android:layout_width="209dp"
        android:layout_height="wrap_content"
        android:layout_alignParentEnd="true"
        android:layout_marginLeft="20dp"
        android:layout_marginTop="70dp"
        android:layout_marginEnd="152dp"
        android:layout_marginBottom="8dp"
        android:padding="8dp"
        android:text="PRICE DETAILS"
        android:fontFamily="@font/montserratbold"
        android:textColor="#FFFFFF"
        android:textSize="18sp"
        android:textStyle="bold" />

    <androidx.cardview.widget.CardView

        android:layout_width="260dp"
        android:layout_height="500dp"
        android:layout_below="@id/priceTitle"
        android:layout_alignParentStart="true"
        android:layout_marginStart="20dp"
        app:cardCornerRadius="16dp"
        app:cardElevation="10dp"
        app:cardBackgroundColor="#FFFFFF">


        <LinearLayout

            android:layout_width="match_parent"
            android:layout_height="377dp"
            android:orientation="vertical"
            android:padding="18dp">


            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/montserratbold"
                android:text="Cart Total"
                android:textColor="#000000" />


            <TextView
                android:id="@+id/basePrice"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/montserratlight"
                android:text="₹0"
                android:textColor="#000000"
                android:textStyle="bold" />


            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:fontFamily="@font/montserratbold"
                android:text="GST (5%)"
                android:textColor="#000000" />


            <TextView
                android:id="@+id/gstPrice"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/montserratlight"
                android:text="₹0"
                android:textColor="#000000" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:fontFamily="@font/montserratbold"
                android:text="Platform Fee"
                android:textColor="#000000" />


            <TextView
                android:id="@+id/platformFee"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/montserratlight"
                android:text="₹0"
                android:textColor="#000000" />

            <View

                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginTop="15dp"
                android:background="#DDDDDD" />


            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:fontFamily="@font/montserratbold"
                android:text="Total Amount"
                android:textColor="#000000"
                android:textStyle="bold" />


            <TextView
                android:id="@+id/totalAmount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/montserratlight"
                android:text="₹0"
                android:textColor="#000000"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:fontFamily="@font/montserratbold"
                android:text="Advance Payment"
                android:textColor="#000000" />


            <TextView
                android:id="@+id/advanceAmount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/montserratlight"
                android:text="₹0"
                android:textColor="#000000"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:fontFamily="@font/montserratbold"
                android:text="Remaining Amount"
                android:textColor="#000000" />

            <TextView
                android:id="@+id/remainingAmount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/montserratlight"
                android:text="₹0"
                android:textColor="#000000"
                android:textStyle="bold" />


        </LinearLayout>

        <Button

            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:id="@+id/payadvance"
            android:layout_alignParentBottom="true"
            android:layout_marginTop="400dp"
            android:layout_marginBottom="20dp"
            android:backgroundTint="#312a44"
            android:text="PAY ADVANCE"
            app:cornerRadius="5dp"
            android:fontFamily="@font/montserratbold"
            android:layout_marginRight="20dp"
            android:layout_marginLeft="20dp"
            android:textStyle="bold"
            android:textColor="@color/white"/>

    </androidx.cardview.widget.CardView>





</RelativeLayout>