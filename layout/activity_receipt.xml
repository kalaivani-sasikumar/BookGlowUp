<?xml version="1.0" encoding="utf-8"?>

<RelativeLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#312a44"
    android:padding="16dp">


    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="RECEIPT"
        android:textColor="#FFFFFF"
        android:textSize="18sp"
        android:fontFamily="@font/montserratbold"
        android:layout_marginTop="60dp"
        android:layout_marginStart="20dp"/>


    <androidx.cardview.widget.CardView

        android:layout_width="260dp"
        android:layout_height="560dp"
        android:layout_marginStart="20dp"
        android:layout_marginEnd="20dp"
        android:layout_marginTop="100dp"
        app:cardCornerRadius="16dp"
        app:cardElevation="10dp"
        app:cardBackgroundColor="#FFFFFF">


        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:padding="18dp">


            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Booking Confirmed!"
                android:textSize="18sp"
                android:textColor="#312a44"
                android:fontFamily="@font/montserratbold"
                android:layout_marginTop="8dp"/>


            <!-- DATE -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Date"
                android:textColor="#312a44"
                android:fontFamily="@font/montserratbold"
                android:layout_marginTop="15dp"/>

            <TextView
                android:id="@+id/receiptDate"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="12/03/2026"
                android:textSize="14sp"
                android:textColor="#555555"
                android:fontFamily="@font/montserratlight"/>


            <!-- TIME -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Time"
                android:textColor="#312a44"
                android:fontFamily="@font/montserratbold"
                android:layout_marginTop="10dp"/>

            <TextView
                android:id="@+id/receiptTime"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="10:00 AM"
                android:textSize="14sp"
                android:textColor="#555555"
                android:fontFamily="@font/montserratlight"/>


            <!-- ADVANCE -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Advance Paid"
                android:textColor="#312a44"
                android:fontFamily="@font/montserratbold"
                android:layout_marginTop="10dp"/>

            <TextView
                android:id="@+id/receiptAdvance"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="₹500"
                android:textSize="14sp"
                android:textColor="#555555"
                android:fontFamily="@font/montserratlight"/>


            <!-- REMAINING -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Remaining Amount"
                android:fontFamily="@font/montserratbold"
                android:textColor="#312a44"
                android:layout_marginTop="10dp"/>

            <TextView
                android:id="@+id/receiptRemaining"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="₹200"
                android:textSize="14sp"
                android:textColor="#555555"
                android:fontFamily="@font/montserratlight"/>


            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="15dp"
                android:text="Services Booked"
                android:fontFamily="@font/montserratbold"
                android:textColor="#312a44"/>


            <androidx.recyclerview.widget.RecyclerView

                android:id="@+id/bookingRecycler"
                android:layout_width="match_parent"
                android:layout_height="150dp"
                android:layout_marginTop="10dp" />


            <!-- pushes button to bottom -->
            <Space
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"/>


            <Button

                android:id="@+id/downloadBtn"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:fontFamily="@font/montserratbold"
                android:text="DOWNLOAD RECEIPT"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:backgroundTint="#312a44"
                android:layout_marginTop="10dp"/>


        </LinearLayout>


    </androidx.cardview.widget.CardView>


</RelativeLayout>