<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    android:id="@+id/main"
    android:background="#F7F8F9">

    <!-- Calendar -->
    <CalendarView
        android:id="@+id/calendarView"
        android:layout_width="match_parent"
        android:layout_height="300dp"
        android:fontFamily="@font/montserratlight"
        android:layout_marginTop="10dp"
        android:textColorPrimary="#312a44"
        android:background="#F7F8F9"
        android:focusedMonthDateColor="#FFFFFF"
        android:unfocusedMonthDateColor="#312a44"
        android:weekNumberColor="#312a44"
        android:weekSeparatorLineColor="#E0E0E0"
        android:selectedWeekBackgroundColor="#88708e"
        android:dateTextAppearance="@style/CalText"
        android:weekDayTextAppearance="@style/CalText"
        android:headerMonthTextAppearance="@style/CalText"
        />

    <!-- Time Slots -->
    <GridLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:columnCount="3"
        android:layout_marginTop="10dp">

        <Button
            android:id="@+id/time10"
            style="@style/timeButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_columnWeight="1"
            android:fontFamily="@font/montserratlight"
            android:text="10.00 am"
            app:backgroundTint="#88708e"
            android:textColor="@color/time_text_color"
            android:background="@drawable/time_bg"
             />

        <Button
            android:id="@+id/time11"
            style="@style/timeButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_columnWeight="1"
            android:background="@drawable/time_bg"
            app:backgroundTint="#88708e"
            android:fontFamily="@font/montserratlight"
            android:text="11.00 am"
            android:textColor="@color/time_text_color" />

        <Button
            android:id="@+id/time12"
            style="@style/timeButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_columnWeight="1"
            android:background="@drawable/time_bg"
            app:backgroundTint="#88708e"
            android:fontFamily="@font/montserratlight"
            android:text="12.00 pm"
            android:textColor="@color/time_text_color" />

        <Button
            android:id="@+id/time1"
            style="@style/timeButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_columnWeight="1"
            android:background="@drawable/time_bg"
            app:backgroundTint="#88708e"
            android:fontFamily="@font/montserratlight"
            android:text="1.00 pm"
            android:textColor="@color/time_text_color" />

        <Button
            android:id="@+id/time2"
            style="@style/timeButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_columnWeight="1"
            android:background="@drawable/time_bg"
            android:fontFamily="@font/montserratlight"
            android:text="2.00 pm"
            app:backgroundTint="#88708e"
            android:textColor="@color/time_text_color" />

        <Button
            android:id="@+id/time3"
            style="@style/timeButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_columnWeight="1"
            android:background="@drawable/time_bg"
            app:backgroundTint="#88708e"
            android:fontFamily="@font/montserratlight"
            android:text="3.00 pm"
            android:textColor="@color/time_text_color" />

        <Button
            android:id="@+id/time4"
            style="@style/timeButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_columnWeight="1"
            android:background="@drawable/time_bg"
            app:backgroundTint="#88708e"
            android:fontFamily="@font/montserratlight"
            android:text="4.00 pm"
            android:textColor="@color/time_text_color" />

        <Button
            android:id="@+id/time5"
            style="@style/timeButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            app:backgroundTint="#88708e"
            android:layout_columnWeight="1"
            android:background="@drawable/time_bg"
            android:fontFamily="@font/montserratlight"
            android:text="5.00 pm"
            android:textColor="@color/time_text_color" />

        <Button
            android:id="@+id/time6"
            style="@style/timeButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_columnWeight="1"
            android:background="@drawable/time_bg"
            android:fontFamily="@font/montserratlight"
            android:text="6.00 pm"
            app:backgroundTint="#88708e"
            android:textColor="@color/time_text_color" />

    </GridLayout>

    <!-- Book Button -->

    <Button
        android:id="@+id/paymentBtn"
        android:layout_width="match_parent"
        android:layout_height="55dp"
        android:text="Book Appointment"
        android:textColor="#FFFFFF"
        android:textStyle="bold"
        android:fontFamily="@font/montserratlight"
        android:backgroundTint="#312a44"
        android:layout_marginTop="20dp"
      />

</LinearLayout>